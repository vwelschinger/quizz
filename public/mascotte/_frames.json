    },
    "badge": {
      "frames": 6,
      "fps": 12,
      "loop": false,
      "then": "idle",
      "note": "badge en main"
    },
    "bataille": {
      "frames": 4,
      "fps": 6,
      "loop": true,
      "note": "casque + couteau"
    },
    "victoire": {
      "frames": 6,
      "fps": 8,
      "loop": true,
      "note": "POST-BATAILLE — casque, danse, 2 couteaux"
    },
    "defaite": {
      "frames": 4,
      "fps": 4,
      "loop": true,
      "note": "POST-BATAILLE — casque, mort sur le côté, yeux en croix, langue"
    },
    "matchnul": {
      "frames": 4,
      "fps": 4,
      "loop": true,
      "note": "POST-BATAILLE — casque, blasé"
    }
