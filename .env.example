# ─── Base de données (Postgres interne du VPS, réseau Docker "stack") ───
# En prod (VPS) : postgresql://<user>:<password>@postgres:5432/quizz
# En local : adapte à ton Postgres de dev.
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/quizz

# ─── Sessions (signature des cookies). Générer : openssl rand -hex 32 ───
SESSION_SECRET=

# ─── Compte admin initial (créé par "npm run seed:admin") ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── API "La Table des Savoirs" ───
# Token initial : sert uniquement au 1er amorçage. Ensuite le token est stocké
# en base (table settings) et rotable via la console admin.
LTDS_API_BASE_URL=https://api.latabledessavoirs.fr
LTDS_API_TOKEN=
# Backfill : 1er jour à importer et nb max de jours par synchro (monter pour un backfill complet en une fois).
LTDS_START_DAY=1
LTDS_MAX_DAYS_PER_SYNC=40

# ─── Synchronisation quotidienne ───
TZ=Europe/Paris
# Planning cron du scheduler interne (node-cron). Ex : "0 6 * * *" = 06:00.
SYNC_CRON=0 6 * * *
# "false" pour désactiver le scheduler interne (ex : si déclenché par n8n / cron hôte).
SYNC_SCHEDULER_ENABLED=true
